APP_NAME=Cinemora Studios API
ENVIRONMENT=development
DEBUG=false
EXPOSE_API_DOCS=true
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cinemora
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=5000
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,[::1],testserver
ENABLE_HTTPS_REDIRECT=false
ENABLE_GZIP=true
ADMIN_API_KEY=change-me
LEAD_RATE_LIMIT=10
LEAD_RATE_LIMIT_WINDOW_SECONDS=60
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
